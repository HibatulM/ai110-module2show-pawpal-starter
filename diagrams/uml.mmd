classDiagram
    class Pet {
        +String id
        +String name
        +String animalType
        +int age
        +String breed
        +String vet
        +String[] dietaryRestrictions
        +String[] medications
        +Owner owner
        +Task[] tasks
        +getPetInfo() String
        +getTaskList() Task[]
        +addTask(task Task) void
        +removeTask(task Task) void
    }

    class Owner {
        +Schedule schedule
        +Pet[] petList
        +Task[] tasksList
        +Map preferences
        +int numberOfPets
        +int numberOfTasks
        +addPet(pet Pet) void
        +removePet(pet Pet) void
        +addTask(task Task) void
        +removeTask(task Task) void
        +getAllTasks() Task[]
        +getTasksForPet(pet Pet) Task[]
        +getSchedule() Schedule
        +generateScheduleForAllPets() Schedule
        +generateScheduleForOnePet(pet Pet) Schedule
        +addPreference(key String, value String) void
        +removePreference(key String) void
    }

    class Task {
        +String id
        +Pet pet
        +String description
        +DateTime scheduledTime
        +String frequency
        +int priority
        +String location
        +int duration
        +DateTime completedTime
        +boolean taskCompleted
        +boolean repeatTask
        +markCompleted(completedTime DateTime) void
        +changePriority(priority int) void
    }

    class Schedule {
        +Owner owner
        +String[] daysOfWeek
        +Time workStart
        +Time workEnd
        +DateTime[][] blockedTimes
        +isTimeFree(start DateTime, end DateTime) boolean
        +findFreeSlot(duration int, after DateTime) DateTime
        +blockTimeForTask(task Task) void
        +blockTimeForRepeatedTask(task Task) void
        +rescheduleTasks() void
        +getUpcomingTasksForDay() Task[]
        +getUpcomingTasksForWeek() Task[]
        +getUpcomingTasksForMonth() Task[]
        +changeTimeForRepeatedTaskOnce(task Task, time DateTime) void
        +changeTimeForTask(task Task, time DateTime) void
    }

    Task --> Pet : belongs to
    Pet --> Owner : owned by
    Schedule --> Owner : belongs to
    Owner --> Schedule : has
